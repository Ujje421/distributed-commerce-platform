# Environment
NODE_ENV=development

# Service Ports
API_GATEWAY_PORT=3000
IDENTITY_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
PRODUCT_CATALOG_SERVICE_PORT=3003
INVENTORY_SERVICE_PORT=3004
CART_SERVICE_PORT=3005
ORDER_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
SHIPPING_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
REVIEW_SERVICE_PORT=3010
RECOMMENDATION_SERVICE_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret_2024
POSTGRES_DB_IDENTITY=identity_db
POSTGRES_DB_USER=user_db
POSTGRES_DB_PRODUCT=product_db
POSTGRES_DB_INVENTORY=inventory_db
POSTGRES_DB_ORDER=order_db
POSTGRES_DB_PAYMENT=payment_db
POSTGRES_DB_SHIPPING=shipping_db
POSTGRES_DB_NOTIFICATION=notification_db
POSTGRES_DB_REVIEW=review_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2024

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ecommerce-platform
KAFKA_GROUP_ID_PREFIX=ecommerce

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin@123456

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ecommerce-assets
MINIO_USE_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/github/callback

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ecommerce-platform
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
JAEGER_UI_PORT=16686
LOKI_PORT=3101

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ecommerce-platform.com

# Feature Flags
FEATURE_FLAGS_ENABLED=true
