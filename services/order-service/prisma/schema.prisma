generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Event Sourcing - Write Model
// ==========================================
model OrderEvent {
  id            String   @id @default(uuid())
  aggregateId   String   // The Order ID
  version       Int      // Sequence number for optimistic concurrency
  eventType     String   // e.g., ORDER_PLACED, ORDER_CONFIRMED, ORDER_CANCELLED
  payload       String   @db.Text
  createdAt     DateTime @default(now())
  correlationId String?

  @@unique([aggregateId, version]) // Ensures strict ordering and prevents concurrent writes
  @@index([aggregateId])
}

// Optional Snapshot table for performance on large aggregates
model OrderSnapshot {
  aggregateId   String   @id
  version       Int
  state         String   @db.Text
  createdAt     DateTime @default(now())
}

// ==========================================
// CQRS - Read Model
// ==========================================
model OrderReadModel {
  id               String   @id
  userId           String
  status           String   // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  totalAmount      Decimal  @db.Decimal(10, 2)
  currency         String
  items            Json     // Denormalized array of items
  shippingAddress  Json     // Denormalized address
  placedAt         DateTime
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ==========================================
// Saga Orchestration State
// ==========================================
model SagaContext {
  sagaId          String   @id @default(uuid())
  orderId         String   @unique
  sagaType        String   @default("ORDER_FULFILLMENT")
  status          String   // STARTED, IN_PROGRESS, COMPLETED, COMPENSATING, COMPENSATED, FAILED
  currentStep     Int      @default(0)
  state           Json     // Stores step results and compensation data
  correlationId   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([status])
}

// ==========================================
// Standard Outbox for reliable event publishing
// ==========================================
model Outbox {
  id            String    @id @default(uuid())
  eventType     String
  topic         String
  partitionKey  String
  payload       String    @db.Text
  correlationId String
  status        String    @default("PENDING")
  retryCount    Int       @default(0)
  maxRetries    Int       @default(5)
  error         String?   @db.Text
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
}
